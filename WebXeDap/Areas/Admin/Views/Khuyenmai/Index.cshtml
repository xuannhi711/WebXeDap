@model IEnumerable<WebXeDap.Models.Khuyenmai>

@{
    ViewData["Title"] = "Danh sách khuyến mãi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}


<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Danh sách khuyến mãi</h2>
        <a class="btn btn-primary" asp-action="Create">+ Thêm khuyến mãi</a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-light">
            <tr>
                <th>Tên khuyến mãi</th>
                <th>Mô tả</th>
                <th>Giảm giá (%)</th>
                <th>Ngày bắt đầu</th>
                <th>Ngày kết thúc</th>
                <th class="text-center" style="width: 180px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">Không có khuyến mãi nào.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TenKhuyenMai</td>
                        <td>@item.MoTa</td>
                        <td>@item.GiamGia%</td>
                        <td>@item.NgayBatDau.ToString("dd/MM/yyyy")</td>
                        <td>@item.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.MaKM">Sửa</a>
                            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.MaKM">Xóa</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
