@model IEnumerable<WebXeDap.Models.Nhacungcap>

@{
    ViewData["Title"] = "Danh sách nhà cung cấp";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<section class="py-4">
    <div class="container">
        <h2 class="mb-4">📦 Danh Sách Nhà Cung Cấp</h2>

        <div class="mb-3 text-end">
            <a asp-action="Add" class="btn btn-success">
                <i class="fas fa-plus me-1"></i> Thêm Nhà Cung Cấp
            </a>
        </div>

        <table class="table table-bordered table-hover shadow-sm">
            <thead class="table-dark text-center">
                <tr>
                    <th>Tên nhà cung cấp</th>
                    <th>Số điện thoại</th>
                    <th>Địa chỉ</th>
                    <th style="width: 180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TenNCC</td>
                        <td>@item.SDT</td>
                        <td>@item.DiaChi</td>
                        <td class="text-center">
                            <a asp-action="Update" asp-route-id="@item.MaNCC" class="btn btn-sm btn-warning me-1">
                                <i class="fas fa-edit"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.MaNCC" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn xóa nhà cung cấp này?');">
                                <i class="fas fa-trash-alt"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
