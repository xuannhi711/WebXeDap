@model IEnumerable<WebXeDap.Models.Loai>

@{
    ViewData["Title"] = "Quản Lý Loại Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<section class="py-4">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">📂 Danh Sách Loại Sản Phẩm</h2>
            <a href="@Url.Action("Add", "Loai", new { area = "Admin" })" class="btn btn-success">
                <i class="fas fa-plus-circle me-1"></i> Thêm Loại Mới
            </a>
        </div>

        <div class="table-responsive shadow-sm">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 30%">Tên loại</th>
                        <th style="width: 50%">Mô tả</th>
                        <th style="width: 20%">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted">Chưa có loại sản phẩm nào.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.TenLoai</td>
                                <td>@item.MoTa</td>
                                <td class="text-center">
                                    <a asp-action="Update" asp-route-id="@item.MaLoai" class="btn btn-sm btn-warning me-1">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaLoai" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn xóa loại này?');">
                                        <i class="fas fa-trash-alt"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
