@model WebXeDap.Models.ApplicationUser
@{
    ViewData["Title"] = "Xóa Khách Hàng"; Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h1>Xóa Khách Hàng</h1>

<h3>Bạn có chắc chắn muốn xóa khách hàng này?</h3>
<div>
    <h4>Khách Hàng</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Tên Đầy Đủ
        </dt>
        <dd class="col-sm-10">
            @Model.FullName
        </dd>
        <dt class="col-sm-2">
            Email
        </dt>
        <dd class="col-sm-10">
            @Model.Email
        </dd>
        <dt class="col-sm-2">
            Địa Chỉ
        </dt>
        <dd class="col-sm-10">
            @Model.Address
        </dd>
        <dt class="col-sm-2">
            Ngày Sinh
        </dt>
        <dd class="col-sm-10">
            @Model.DateOfBirth.ToString("dd/MM/yyyy")
        </dd>
        <dt class="col-sm-2">
            Ngày Tạo
        </dt>
        <dd class="col-sm-10">
            @Model.CreatedDate.ToString("dd/MM/yyyy")
        </dd>
    </dl>
</div>
<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <input type="submit" value="Xóa" class="btn btn-danger" /> |
        <a asp-action="CustomerList" class="btn btn-primary">Quay Lại</a>
    </div>
</form>
