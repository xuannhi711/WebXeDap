@model WebXeDap.Models.Hoadon

@{
    ViewData["Title"] = "Chi tiết hóa đơn";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string FormatVND(decimal amount) => string.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:C0}", amount);
}

<div class="container py-4">
    <h2 class="mb-4 text-primary">Chi tiết hóa đơn</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Hóa đơn #@Model.MaHD</h5>
        </div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-md-6"><strong>Ngày lập:</strong> @Model.NgayLapHD.ToString("dd/MM/yyyy")</div>
                <div class="col-md-6"><strong>Tổng tiền:</strong> @FormatVND(Model.TongTien)</div>
            </div>
            <div class="mb-2"><strong>Địa chỉ giao hàng:</strong> @Model.DiaChiGiaoHang</div>
            <div class="mb-2"><strong>Ghi chú:</strong> @Model.GhiChu</div>
            <div><strong>Trạng thái:</strong> @Model.TrangThai</div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">Chi tiết sản phẩm</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Chitiethoadons)
                    {
                        <tr>
                            <td>@item.Sanpham.TenSP</td>
                            <td class="text-center">@item.SoLuong</td>
                            <td class="text-end">@FormatVND(item.DonGia)</td>
                            <td class="text-end">@FormatVND(item.SoLuong * item.DonGia)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>
