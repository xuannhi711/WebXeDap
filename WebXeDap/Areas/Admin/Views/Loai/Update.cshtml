@model WebXeDap.Models.Loai

@{
    ViewData["Title"] = "Cập nhật loại sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<section class="py-4">
    <div class="container">
        <h2 class="mb-4 text-warning">
            <i class="fas fa-edit me-2"></i>Cập Nhật Loại Sản Phẩm
        </h2>

        <form asp-action="Update" method="post" class="shadow p-4 rounded bg-white border">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="MaLoai" />

            <div class="mb-3">
                <label asp-for="TenLoai" class="form-label fw-semibold">Tên loại <span class="text-danger">*</span></label>
                <input asp-for="TenLoai" class="form-control" placeholder="VD: Xe Đạp Địa Hình" />
                <span asp-validation-for="TenLoai" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MoTa" class="form-label fw-semibold">Mô tả</label>
                <input asp-for="MoTa" class="form-control" placeholder="Thông tin mô tả chi tiết..." />
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
