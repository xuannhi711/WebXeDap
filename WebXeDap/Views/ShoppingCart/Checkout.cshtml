@model WebXeDap.Models.ShoppingCart
@{
    ViewData["Title"] = "Thanh Toán";
    var totalAmount = Model.Items?.Sum(item => item.DonGia * item.SoLuong) ?? 0;
}

<div class="container py-5">
    <h2 class="text-center mb-4 fw-bold text-primary">XÁC NHẬN ĐƠN HÀNG</h2>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Sản phẩm trong giỏ hàng</h5>
                </div>
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Màu</th>
                                <th>Số lượng</th>
                                <th>Đơn giá</th>
                                <th>Thành tiền</th>
                                <th>Xoá</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Items != null && Model.Items.Any())
                            {
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>@item.MaSP</td>
                                        <td>@item.Mau</td>
                                        <td>@item.SoLuong</td>
                                        <td>@item.DonGia.ToString("N0") đ</td>
                                        <td>@((item.DonGia * item.SoLuong).ToString("N0")) đ</td>
                                        <td>
                                            <a asp-action="RemoveFromCart" asp-route-MaSP="@item.MaSP" class="btn btn-sm btn-outline-danger">Xoá</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">Không có sản phẩm nào trong giỏ hàng.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Tóm tắt đơn hàng</h5>
                </div>
                <div class="card-body">
                    <p class="mb-2 fw-semibold">Tổng tiền:</p>
                    <h4 class="text-danger fw-bold">@totalAmount.ToString("N0") đ</h4>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-3">← Tiếp tục mua sắm</a>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <h4 class="mb-4 text-primary fw-semibold">Thông tin giao hàng</h4>
    <form asp-action="Checkout" method="post">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label for="tinh">Tỉnh/Thành phố</label>
                    <select class="form-select" id="tinh" name="tinh" required>
                        <option value="0">Chọn tỉnh/thành</option>
                    </select>
                    <input type="hidden" id="tinhName" name="tinhName" />
                </div>
                <div class="form-group mb-3">
                    <label for="quan">Quận/Huyện</label>
                    <select class="form-select" id="quan" name="quan" required>
                        <option value="0">Chọn quận/huyện</option>
                    </select>
                    <input type="hidden" id="quanName" name="quanName" />
                </div>
                <div class="form-group mb-3">
                    <label for="phuong">Phường/Xã</label>
                    <select class="form-select" id="phuong" name="phuong" required>
                        <option value="0">Chọn phường/xã</option>
                    </select>
                    <input type="hidden" id="phuongName" name="phuongName" />
                </div>
                <div class="form-group mb-3">
                    <label for="diachi">Địa chỉ chi tiết</label>
                    <input type="text" class="form-control" id="diachi" name="diachi" placeholder="Ví dụ: Số 123, đường ABC" required>
                </div>
                <div class="form-group mb-3">
                    <label for="PhoneNumber">Số điện thoại</label>
                    <input type="tel" class="form-control" id="PhoneNumber" name="PhoneNumber" required>
                </div>
                <div class="form-group mb-3">
                    <label for="GhiChu">Ghi chú</label>
                    <textarea class="form-control" id="GhiChu" name="GhiChu" rows="3" placeholder="Ghi chú thêm (nếu có)"></textarea>
                </div>
            </div>
            <div class="col-md-6">
                <h5 class="mb-3">Hình thức thanh toán</h5>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="PaymentMethod" id="paymentCOD" value="COD" checked>
                    <label class="form-check-label" for="paymentCOD">
                        Thanh toán khi nhận hàng (COD)
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="PaymentMethod" id="paymentVNPAY" value="VNPAY">
                    <label class="form-check-label" for="paymentVNPAY">
                        Thanh toán qua VNPAY (Online)
                    </label>
                </div>
            </div>
        </div>
        <div class="text-end mt-4">
            <button type="submit" class="btn btn-primary px-4 py-2">Đặt hàng</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Lấy tỉnh thành
            $.getJSON('https://esgoo.net/api-tinhthanh/1/0.htm', function (data_tinh) {
                if (data_tinh.error == 0) {
                    $.each(data_tinh.data, function (key_tinh, val_tinh) {
                        $("#tinh").append('<option value="' + val_tinh.id + '">' + val_tinh.full_name + '</option>');
                    });
                    $("#tinh").change(function () {
                        var idtinh = $(this).val();
                        $("#tinhName").val($("#tinh option:selected").text());
                        $.getJSON('https://esgoo.net/api-tinhthanh/2/' + idtinh + '.htm', function (data_quan) {
                            if (data_quan.error == 0) {
                                $("#quan").html('<option value="0">Quận Huyện</option>');
                                $("#phuong").html('<option value="0">Phường Xã</option>');
                                $.each(data_quan.data, function (key_quan, val_quan) {
                                    $("#quan").append('<option value="' + val_quan.id + '">' + val_quan.full_name + '</option>');
                                });
                                $("#quan").change(function () {
                                    var idquan = $(this).val();
                                    $("#quanName").val($("#quan option:selected").text());
                                    $.getJSON('https://esgoo.net/api-tinhthanh/3/' + idquan + '.htm', function (data_phuong) {
                                        if (data_phuong.error == 0) {
                                            $("#phuong").html('<option value="0">Phường Xã</option>');
                                            $.each(data_phuong.data, function (key_phuong, val_phuong) {
                                                $("#phuong").append('<option value="' + val_phuong.id + '">' + val_phuong.full_name + '</option>');
                                            });
                                            $("#phuong").change(function () {
                                                $("#phuongName").val($("#phuong option:selected").text());
                                            });
                                        }
                                    });
                                });
                            }
                        });
                    });
                }
            });
        });
    </script>
}