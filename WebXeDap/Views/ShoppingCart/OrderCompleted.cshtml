@model WebXeDap.Models.Hoadon

@{
    ViewData["Title"] = "Đơn Hàng Hoàn Tất";
}

<div class="container mt-4">
    <div class="card shadow-lg rounded-3 p-4">
        <h2 class="text-success text-center">🎉 Đặt Hàng Thành Công! 🎉</h2>
        <p class="text-center text-muted">Cảm ơn bạn đã mua hàng! Đơn hàng của bạn đã được ghi nhận.</p>

        <div class="mt-3">
            <p><strong>Mã đơn hàng:</strong> @Model.MaHD</p>
            <p><strong>Tổng tiền:</strong> @Model.TongTien.ToString("N0") VNĐ</p>
            <p><strong>Trạng thái:</strong> @Model.TrangThai</p>
        </div>

        <div class="text-center mt-4">
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Tiếp tục mua sắm</a>
            <a href="@Url.Action("Details", "Hoadon", new { id = Model.MaHD })" class="btn btn-success">Xem chi tiết đơn hàng</a>
        </div>
    </div>
</div>
