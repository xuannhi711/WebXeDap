<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <title>TVBike</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="Free HTML Templates" name="keywords">
    <meta content="Free HTML Templates" name="description">
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Custom Styles (Make sure the path is correct for your project structure) -->
    <link href="~/css/style.css" rel="stylesheet">
    <style>
        .zalo-float {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 50px;
            height: 50px;
            background-color: #007aff;
            border-radius: 50%;
            box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            transition: transform 0.3s;
        }

            .zalo-float:hover {
                transform: scale(1.1);
            }

        .zalo-icon {
            width: 35px;
            height: 35px;
        }

        .product-img img {
            transition: transform 0.3s ease-in-out;
        }

        .product-img:hover img {
            transform: scale(1.1);
        }


    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top border-bottom">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-primary" href="#">
                <i class="fas fa-bicycle me-2"></i>TV Bike
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-1"></i>Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="SanPham" asp-action="Index"><i class="bi bi-box-seam me-1"></i>Sản phẩm</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="tintuc" asp-action="Index"><i class="bi bi-newspaper me-1"></i>Tin tức</a>
                    </li>

                    <!-- Danh Mục Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-dark" href="#" id="categoryDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-list-ul me-1"></i>Danh Mục
                        </a>
                        <ul class="dropdown-menu">
                            @if (ViewBag.DanhMuc != null)
                            {
                                @foreach (var loai in ViewBag.DanhMuc)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Home" asp-action="Index" asp-route-danhMucId="@loai.MaLoai">
                                            @loai.TenLoai
                                        </a>
                                    </li>
                                }
                            }
                            else
                            {
                                <li><a class="dropdown-item" href="#">Không có danh mục</a></li>
                            }
                        </ul>
                    </li>

                    <!-- Quản lý đơn hàng Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-dark" href="#" id="orderDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-receipt me-1"></i>Đơn hàng
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="HoaDon" asp-action="Index">Lịch sử mua hàng</a></li>
                            <li><a class="dropdown-item" asp-controller="HoaDon" asp-action="DanhSachBaoHanh">Bảo hành sản phẩm</a></li>
                        </ul>
                    </li>
                </ul>

                <!-- Form tìm kiếm -->
                <form class="d-flex me-3" asp-controller="Home" asp-action="Index" method="get">
                    <input class="form-control form-control-sm me-2" type="search" name="search"
                           placeholder="Tìm kiếm xe..." aria-label="Search">
                    <button class="btn btn-sm btn-outline-primary" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <!-- Partial login -->
                <partial name="_LoginPartial" />

                <!-- Giỏ hàng -->
                <a asp-controller="ShoppingCart" asp-action="Index" class="btn btn-sm btn-primary ms-2 d-flex align-items-center">
                    <i class="fas fa-shopping-cart me-1"></i> Giỏ hàng
                </a>
            </div>
        </div>
    </nav>


    <!-- Main content area -->
    <div class="container-fluid" style="padding-top: 80px;">
        <main>
            @RenderBody()
        </main>
    </div>

    <!-- Nút liên hệ Zalo nổi -->
    <a href="https://zalo.me/your_phone_number" target="_blank" class="zalo-float">
        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/Icon_of_Zalo.svg/120px-Icon_of_Zalo.svg.png"
             alt="Zalo" class="zalo-icon">
    </a>
    <!-- Back-to-top Button -->
    <a href="#" class="btn btn-primary back-to-top" style="position: fixed; bottom: 20px; right: 20px; display: none;">
        <i class="fa fa-angle-double-up"></i>
    </a>




    <footer class="bg-light text-dark mt-5 pt-4 pb-3">
        <div class="container-fluid px-5">
            <div class="row text-center text-md-start">
                <!-- Cột 1: Thông tin cửa hàng -->
                <div class="col-md-4 mb-3">
                    <h5 class="text-primary fw-bold">BikeShop</h5>
                    <p>Chuyên cung cấp các dòng xe đạp chất lượng cao với giá tốt nhất.</p>
                    <p><i class="fa fa-map-marker-alt text-primary me-2"></i>123 Đường ABC, TP. HCM</p>
                    <p><i class="fa fa-envelope text-primary me-2"></i>contact@bikeshop.com</p>
                    <p><i class="fa fa-phone-alt text-primary me-2"></i>0909 123 456</p>
                </div>

                <!-- Cột 2: Liên kết nhanh -->
                <div class="col-md-4 mb-3">
                    <h5 class="text-primary fw-bold">Liên kết</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-dark text-decoration-none">Trang chủ</a></li>
                        <li><a href="#" class="text-dark text-decoration-none">Sản phẩm</a></li>
                        <li><a href="#" class="text-dark text-decoration-none">Khuyến mãi</a></li>
                        <li><a href="#" class="text-dark text-decoration-none">Liên hệ</a></li>
                    </ul>
                </div>

                <!-- Cột 3: Mạng xã hội -->
                <div class="col-md-4 mb-3">
                    <h5 class="text-primary fw-bold">Kết nối với chúng tôi</h5>
                    <a href="#" class="text-dark me-3"><i class="fab fa-facebook fa-lg"></i></a>
                    <a href="#" class="text-dark me-3"><i class="fab fa-instagram fa-lg"></i></a>
                    <a href="#" class="text-dark me-3"><i class="fab fa-youtube fa-lg"></i></a>
                    <a href="#" class="text-dark"><i class="fab fa-twitter fa-lg"></i></a>
                </div>
            </div>

            <div class="text-center pt-3 border-top">
                <p class="mb-0">&copy; 2025 BikeShop. All rights reserved.</p>
            </div>
        </div>
    </footer>






    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  
    <script>
        
        $(window).scroll(function () {
            if ($(this).scrollTop() > 200) {
                $('.back-to-top').fadeIn();
            } else {
                $('.back-to-top').fadeOut();
            }
        });

      
        $('.back-to-top').click(function () {
            $('html, body').animate({ scrollTop: 0 }, '300');
            return false;
        });
    </script>

    <!-- Custom Scripts -->
    @RenderSection("Scripts", required: false)
</body>

</html>
