@model WebXeDap.Models.Sanpham

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h1 class="text-center">Xác nhận xóa sản phẩm</h1>

<div class="container">
    <h3 class="text-danger">Bạn chắc chắn muốn xóa sản phẩm này?</h3>
    <div class="row">
        <div class="col-md-6">
            <h4>Chi tiết sản phẩm</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.TenSP)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.TenSP)
                </dd>

                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.GiaMua)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.GiaMua)
                </dd>

                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.GiaBan)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.GiaBan)
                </dd>

                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.GiaKhuyenMai)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.GiaKhuyenMai)
                </dd>

                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.SoLuongTon)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.SoLuongTon)
                </dd>

                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Loai)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Loai.MaLoai)
                </dd>

                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Nhacungcap)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Nhacungcap.MaNCC)
                </dd>

                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Khuyenmai)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Khuyenmai.MaKM)
                </dd>
            </dl>
        </div>

        <div class="col-md-6">
            <h5>Ảnh sản phẩm</h5>
            <div>
                @foreach (var image in Model.Anhs)
                {
                    <img src="@image.Url" alt="@Model.TenSP" class="img-fluid rounded mb-3" width="200" />
                }
            </div>
        </div>
    </div>

    <div class="mt-4">
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="MaSP" />
            <button type="submit" class="btn btn-danger">Xóa sản phẩm</button>
            <a class="btn btn-secondary" asp-action="Index">Quay lại danh sách</a>
        </form>
    </div>
</div>
