@model WebXeDap.Models.ShoppingCart

<section class="py-5" style="background-color: #f0f8ff;">
    <div class="container">
        <h2 class="text-center mb-4 text-primary">🛒 Giỏ Hàng</h2>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-info text-center">
                @TempData["Message"]
            </div>
        }

        <p class="text-center text-muted mb-4">
            Bạn có <strong class="text-primary">@Model.Items.Count()</strong> sản phẩm trong giỏ hàng
        </p>

        <div class="table-responsive">
            <table class="table align-middle shadow-sm border border-info-subtle">
                <thead style="background-color: #e0f7fa;">
                    <tr class="text-primary">
                        <th style="width:40%">Sản phẩm</th>
                        <th style="width:15%">Màu sắc</th>
                        <th style="width:15%">Giá</th>
                        <th style="width:15%">Số lượng</th>
                        <th style="width:15%">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="@item.HinhAnh" alt="@item.MaSP" class="img-thumbnail me-3" style="width: 80px; height: 80px; object-fit: cover;">
                                    <div>
                                        <h6 class="mb-1 text-primary">@item.MaSP</h6>
                                        <small class="text-muted">Mã sản phẩm: @item.MaSP</small>
                                    </div>
                                </div>
                            </td>

                            <td class="text-center">@item.Mau</td>

                            <td class="text-center text-success fw-bold">@item.DonGia.ToString("N0") đ</td>

                            <td>
                                <div class="d-flex justify-content-center align-items-center">
                                    <a asp-action="GiamSL" asp-route-productId="@item.MaSP" class="btn btn-outline-info btn-sm px-2">−</a>
                                    <input type="text" class="form-control text-center mx-2" value="@item.SoLuong" style="width: 50px;" readonly />
                                    <a asp-action="TangSL" asp-route-productId="@item.MaSP" class="btn btn-outline-info btn-sm px-2">+</a>
                                </div>
                            </td>

                            <td class="text-center">
                                <form asp-action="RemoveFromCart" method="post">
                                    <input type="hidden" name="MaSP" value="@item.MaSP" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash-alt me-1"></i> Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-end mt-4">
            <h4 class="fw-bold text-primary">Tổng tiền:</h4>
            <h2 class="text-success">@Model.Items.Sum(item => item.DonGia * item.SoLuong).ToString("N0") đ</h2>
        </div>

        <div class="row mt-5">
            <div class="col-md-6 text-start">
                <a href="/Home/Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Tiếp tục mua hàng
                </a>
            </div>

            <div class="col-md-6 text-end">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="ShoppingCart" asp-action="Checkout" class="btn btn-info px-5 text-white">
                        Mua Hàng
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/ShoppingCart/Checkout" class="btn btn-info px-5 text-white">
                        Đăng nhập để mua
                    </a>
                }
            </div>
        </div>
    </div>
</section>
