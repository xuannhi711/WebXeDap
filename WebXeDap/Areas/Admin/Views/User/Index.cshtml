@model IEnumerable<WebXeDap.Models.ApplicationUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Danh Sách Người Dùng";
    var roles = ViewBag.Roles as List<IdentityRole>;
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h1>Danh Sách Người Dùng</h1>

<table class="table">
    <thead>
        <tr>
            <th>Tên Đầy Đủ</th>
            <th>Email</th>
            <th>Quyền</th>
            <th>Hành Động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>
                    @foreach (var role in roles)
                    {
                        @if (await UserManager.IsInRoleAsync(user, role.Name))
                        {
                            <span class="badge bg-success">@role.Name</span>
                        }
                    }
                </td>
                <td>
                    <form method="post" asp-action="ChangeRole" asp-controller="User" asp-area="Admin">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <select name="role" class="form-select">
                            @foreach (var role in roles)
                            {
                                <option value="@role.Name">@role.Name</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-warning">Thay Đổi Quyền</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-action="Index" class="btn btn-primary">Quay Lại</a>
</div>
