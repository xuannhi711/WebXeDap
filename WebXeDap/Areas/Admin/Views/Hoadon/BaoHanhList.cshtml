@model IEnumerable<WebXeDap.Models.Baohanh>
@{
    ViewData["Title"] = "Danh Sách Bảo Hành"; Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h1>Danh Sách Bảo Hành</h1>

<form method="get" asp-action="BaoHanhList">
    <div class="form-group">
        <label for="searchString">Tìm kiếm:</label>
        <input type="text" name="searchString" class="form-control" />
    </div>
    <div class="form-group">
        <label for="searchType">Tìm theo:</label>
        <select name="searchType" class="form-control">
            <option value="MaBaoHanh">Mã Bảo Hành</option>
            <option value="UserId">UserId</option>
            <option value="Email">Email</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Tìm kiếm</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Mã Bảo Hành</th>
            <th>Mã Hóa Đơn</th>
            <th>Mã Sản Phẩm</th>
            <th>Thời Hạn Bảo Hành</th>
            <th>Điều Kiện Bảo Hành</th>
            <th>Ngày Tạo</th>
            <th>Ngày Hết Hạn</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var baohanh in Model)
        {
            <tr>
                <td>@baohanh.MaBaoHanh</td>
                <td>@baohanh.MaHD</td>
                <td>@baohanh.MaSP</td>
                <td>@baohanh.ThoiHanBaoHanh tháng</td>
                <td>@baohanh.DieuKienBaoHanh</td>
                <td>@baohanh.NgayTaoBaoHanh.ToString("dd/MM/yyyy")</td>
                <td>@baohanh.NgayHetHanBaoHanh.ToString("dd/MM/yyyy")</td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-action="Index" class="btn btn-primary">Quay Lại</a>
</div>

