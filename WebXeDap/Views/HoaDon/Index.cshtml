@model IEnumerable<WebXeDap.Models.Hoadon>

@{
    ViewData["Title"] = "Danh sách hóa đơn";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string FormatVND(decimal amount) => string.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:C0}", amount);
}

<div class="container py-4">
    <h2 class="mb-4 text-primary">Danh sách hóa đơn</h2>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Mã hóa đơn</th>
                        <th scope="col">Ngày lập</th>
                        <th scope="col" class="text-end">Tổng tiền</th>
                        <th scope="col">Trạng thái</th>
                        <th scope="col" class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hoadon in Model)
                    {
                        <tr>
                            <td>@hoadon.MaHD</td>
                            <td>@hoadon.NgayLapHD.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">@FormatVND(hoadon.TongTien)</td>
                            <td>
                                @if (hoadon.TrangThai == "Đã thanh toán")
                                {
                                    <span class="badge bg-success">@hoadon.TrangThai</span>
                                }
                                else if (hoadon.TrangThai == "Đang xử lý")
                                {
                                    <span class="badge bg-warning text-dark">@hoadon.TrangThai</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@hoadon.TrangThai</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@hoadon.MaHD" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
