@page
@model WebXeDap.AdminPanel.Pages.ProductCategoriesModel
@{
    ViewData["Title"] = "Product Categories";
}

<div class="mb-3">
    <h3>Manage Product Categories</h3>
    <p class="text-muted">Select a product and toggle its categories.</p>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label">Product</label>
        <select class="form-select" name="ProductId" onchange="this.form.submit()">
            <option value="">-- select product --</option>
            @foreach (var p in Model.Products)
            {
                <option value="@p.Id" selected="@(Model.ProductId == p.Id)">@p.Name</option>
            }
        </select>
    </div>
</form>

@if (Model.ProductId > 0)
{
    <form method="post">
        <input type="hidden" name="ProductId" value="@Model.ProductId" />
        <div class="mb-3">
            <label class="form-label">Categories</label>
            <div class="border p-2">
                @foreach (var c in Model.Categories)
                {
                    var isChecked = Model.SelectedCategoryIds.Contains(c.Id);
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="SelectedCategoryIds" value="@c.Id" id="cat@c.Id" @(isChecked ? "checked" : "") />
                        <label class="form-check-label" for="cat@c.Id">@c.Name</label>
                    </div>
                }
            </div>
        </div>
        <button class="btn btn-primary">Save</button>
    </form>
}
