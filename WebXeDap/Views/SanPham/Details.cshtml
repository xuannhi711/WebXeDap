@model WebXeDap.Models.Sanpham
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container py-5">
    <div class="row g-4">

        <!-- Hình ảnh sản phẩm -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body p-3">
                    <div class="position-relative text-center" style="height: 400px; background-color: #f0f0f0;">
                        <!-- Nút chuyển ảnh -->
                        <button class="btn btn-outline-secondary position-absolute top-50 start-0 translate-middle-y rounded-circle"
                                onclick="changeImage(-1)">
                            ❮
                        </button>

                        <img id="mainImage" src="@Model.Anhs?.FirstOrDefault()?.Url"
                             class="img-fluid h-100"
                             style="object-fit: contain;" alt="@Model.TenSP" />

                        <button class="btn btn-outline-secondary position-absolute top-50 end-0 translate-middle-y rounded-circle"
                                onclick="changeImage(1)">
                            ❯
                        </button>
                    </div>

                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-3">
                        @foreach (var anh in Model.Anhs ?? new List<WebXeDap.Models.Anh>())
                        {
                            <img src="@anh.Url" class="thumbnail-img" onclick="document.getElementById('mainImage').src='@anh.Url'" />
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body p-4">
                    <h3 class="fw-semibold mb-3">@Model.TenSP</h3>

                    <!-- Giá -->
                    <div class="mb-3">
                        <h4 class="text-danger fw-bold d-inline">@Model.GiaMua.ToString("N0") đ</h4>
                        <small class="text-muted text-decoration-line-through ms-3">@Model.GiaBan.ToString("N0") đ</small>
                    </div>

                    <!-- Màu sắc -->
                    <div class="mb-4">
                        <h6 class="fw-bold">Màu sắc:</h6>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var mau in Model.Mau ?? new List<WebXeDap.Models.Mau>())
                            {
                                <div class="form-check d-flex align-items-center">
                                    <input class="form-check-input" type="radio" name="SelectedMau" id="mau_@mau.Id"
                                           value="@mau.TenMau" onchange="updateSelectedMau('@mau.TenMau')" hidden>
                                    <label for="mau_@mau.Id" class="color-box" style="background-color: @mau.TenMau;"></label>
                                    <span class="ms-2">@mau.TenMau</span>
                                </div>
                            }
                        </div>
                        <input type="hidden" name="mau" id="SelectedMau" value="@((Model.Mau != null && Model.Mau.Count > 0) ? Model.Mau.First().TenMau : "Mặc định")">
                    </div>

                    <!-- Số lượng -->
                    <div class="mb-4">
                        <h6 class="fw-bold">Số lượng:</h6>
                        <div class="input-group" style="width: 150px;">
                            <button class="btn btn-outline-secondary" type="button" onclick="changeQuantity(-1)">−</button>
                            <input type="text" id="SoLuong" class="form-control text-center" value="1" readonly>
                            <button class="btn btn-outline-secondary" type="button" onclick="changeQuantity(1)">+</button>
                        </div>
                    </div>

                    <!-- Nút thêm vào giỏ -->
                    <form asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-masp="@Model.MaSP" method="post">
                        <input type="hidden" name="sl" id="HiddenSoLuong" value="1" />
                        <input type="hidden" name="mau" id="HiddenSelectedMau" value="@((Model.Mau != null && Model.Mau.Count > 0) ? Model.Mau.First().TenMau : "Mặc định")" />
                        <button type="submit" class="btn btn-success w-100">🛒 Thêm vào giỏ hàng</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Mô tả sản phẩm -->
    <div class="mt-5">
        <h5 class="fw-bold mb-3">Mô tả sản phẩm</h5>
        <div class="p-3 rounded bg-white shadow-sm">
            <p>@Html.Raw(Model.mota)</p>
        </div>
    </div>
</div>

<!-- CSS -->
<style>
    .color-box {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 2px solid #ccc;
        cursor: pointer;
        transition: 0.2s;
    }

    input:checked + .color-box {
        border-color: #333;
        box-shadow: 0 0 5px #333;
    }

    .thumbnail-img {
        width: 75px;
        height: 75px;
        object-fit: cover;
        border-radius: 6px;
        border: 2px solid #ddd;
        padding: 4px;
        cursor: pointer;
        transition: transform 0.2s;
    }

        .thumbnail-img:hover {
            transform: scale(1.1);
            border-color: #28a745;
        }
</style>

<!-- JavaScript -->
<script>
    function changeQuantity(value) {
        let qtyInput = document.getElementById('SoLuong');
        let hiddenInput = document.getElementById('HiddenSoLuong');
        let newValue = Math.max(1, parseInt(qtyInput.value) + value);
        qtyInput.value = hiddenInput.value = newValue;
    }

    function updateSelectedMau(colorName) {
        document.getElementById("HiddenSelectedMau").value = colorName;
    }

    let currentIndex = 0;
    let images = @Html.Raw(Json.Serialize(Model.Anhs?.Select(a => a.Url) ?? new List<string>()));

    function changeImage(direction) {
        if (images.length === 0) return;
        currentIndex = (currentIndex + direction + images.length) % images.length;
        document.getElementById("mainImage").src = images[currentIndex];
    }
</script>
