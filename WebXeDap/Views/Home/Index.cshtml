@model IEnumerable<WebXeDap.Models.Sanpham>

@{
    ViewData["Title"] = "Danh sách xe đạp";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int numOfquanity = 1;
}

<!-- Carousel Section -->
<div id="header-carousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active" style="height: 410px;">
            <img class="img-fluid w-100" src="img/Poster-1.jpg" alt="Image">
            <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                <div class="p-3" style="max-width: 700px;">
                    <h4 class="text-light text-uppercase font-weight-medium mb-3">- Sáng Tạo -</h4>
                    <h3 class="display-4 text-white font-weight-semi-bold mb-4">Trẻ Trung Năng Động</h3>
                    <a href="#" class="btn btn-light py-2 px-3">Shop Now</a>
                </div>
            </div>
        </div>
        <div class="carousel-item" style="height: 410px;">
            <img class="img-fluid w-100" src="img/Poster-2.jpg" alt="Image">
            <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                <div class="p-3" style="max-width: 700px;">
                    <h4 class="text-light text-uppercase font-weight-medium mb-3">Nhiệt Tình</h4>
                    <h3 class="display-4 text-white font-weight-semi-bold mb-4">Đồng Hành Cùng Bạn</h3>
                    <a href="#" class="btn btn-light py-2 px-3">Shop Now</a>
                </div>
            </div>
        </div>
    </div>
    <a class="carousel-control-prev" href="#header-carousel" data-bs-slide="prev">
        <div class="btn btn-dark" style="width: 45px; height: 45px;">
            <span class="carousel-control-prev-icon mb-n2"></span>
        </div>
    </a>
    <a class="carousel-control-next" href="#header-carousel" data-bs-slide="next">
        <div class="btn btn-dark" style="width: 45px; height: 45px;">
            <span class="carousel-control-next-icon mb-n2"></span>
        </div>
    </a>
</div>

<!-- Title Section -->
<div class="text-center mb-4">
    <h2 class="section-title px-5"><span class="px-2">Danh sách xe đạp</span></h2>
</div>

<!-- Product Grid -->
<div class="row px-xl-5 pb-3">
    @foreach (var item in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6 pb-1">
            <div class="card product-item border-0 mb-4 shadow-sm">
                <!-- Product Image -->
                <div class="card-header product-img position-relative overflow-hidden bg-transparent border p-0" style="aspect-ratio: 4/3; height: auto;">
                    <img class="img-fluid w-100 h-100" src="@(item?.Anhs?.FirstOrDefault()?.Url ?? "/images/no-image.png")" alt="@item.TenSP" style="object-fit: cover;">
                </div>

                <!-- Product Info -->
                <div class="card-body border-left border-right text-center p-0 pt-4 pb-3">
                    <!-- Product Name -->
                    <h6 class="text-truncate mb-3">@item.TenSP</h6>

                    <!-- Price -->
                    <div class="d-flex justify-content-center">
                        <h6 class="text-danger fw-bold">@item.GiaMua đ</h6>
                        <h6 class="text-muted ms-2"><del>@item.GiaBan đ</del></h6>
                    </div>
                </div>

                <!-- Footer with Actions -->
                <div class="card-footer d-flex justify-content-between bg-light border">
                    <!-- View Details Button -->
                    <a asp-controller="SanPham" asp-action="Details" asp-route-id="@item.MaSP"
                       class="btn btn-link text-primary text-decoration-none p-0">
                        <i class="fas fa-eye me-1"></i> Xem chi tiết
                    </a>


                    <!-- Add to Cart Button -->
                    <form asp-controller="ShoppingCart" asp-action="AddToCart"
                          method="post" class="d-inline">
                        <input type="hidden" name="MaSP" value="@item.MaSP">
                        <input type="hidden" name="Mau" value="@((item.Mau != null && item.Mau.Any()) ? item.Mau.First().TenMau : "Mặc định")">
                        <input type="hidden" name="SoLuong" value="@numOfquanity">
                        <button type="submit" class="btn btn-sm btn-link text-success text-decoration-none p-0">
                            <i class="fas fa-shopping-cart me-1"></i> Thêm vào giỏ
                        </button>
                    </form>



                </div>
            </div>
        </div>
    }
</div>
