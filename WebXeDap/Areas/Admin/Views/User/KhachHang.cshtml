@model IEnumerable<WebXeDap.Models.ApplicationUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Danh Sách Khách Hàng"; Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var newCustomersCount = ViewBag.NewCustomersCount;
}

<h1>Danh Sách Khách Hàng</h1>

<p>Số lượng khách hàng mới trong 3 ngày qua: <strong>@newCustomersCount</strong></p>

<table class="table">
    <thead>
        <tr>
            <th>Tên Đầy Đủ</th>
            <th>Email</th>
            <th>Quyền</th>
            <th>Ngày Tạo</th>
            <th>Hành Động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>
                    @foreach (var role in await UserManager.GetRolesAsync(user))
                    {
                        <span class="badge bg-success">@role</span>
                    }
                </td>
                <td>@user.CreatedDate.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-info">Xem</a>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-primary">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-controller="User" asp-action="Index" class="btn btn-primary">Quay Lại</a>
</div>
