@model WebXeDap.Models.Nhacungcap

@{
    ViewData["Title"] = "Thêm nhà cung cấp";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<section class="py-4">
    <div class="container">
        <h2 class="mb-4 text-success">
            <i class="fas fa-plus-circle me-2"></i>Thêm Nhà Cung Cấp Mới
        </h2>

        <form asp-action="Add" method="post" class="shadow p-4 rounded bg-white border">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="MaNCC" class="form-label fw-semibold">Mã NCC <span class="text-danger">*</span></label>
                <input asp-for="MaNCC" class="form-control" placeholder="Nhập mã nhà cung cấp (VD: NCC01)" />
                <span asp-validation-for="MaNCC" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TenNCC" class="form-label fw-semibold">Tên nhà cung cấp <span class="text-danger">*</span></label>
                <input asp-for="TenNCC" class="form-control" placeholder="Nhập tên nhà cung cấp" />
                <span asp-validation-for="TenNCC" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SDT" class="form-label fw-semibold">Số điện thoại</label>
                <input asp-for="SDT" class="form-control" placeholder="Nhập số điện thoại liên hệ" />
                <span asp-validation-for="SDT" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DiaChi" class="form-label fw-semibold">Địa chỉ</label>
                <input asp-for="DiaChi" class="form-control" placeholder="Nhập địa chỉ nhà cung cấp" />
                <span asp-validation-for="DiaChi" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-1"></i> Thêm mới
                </button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
