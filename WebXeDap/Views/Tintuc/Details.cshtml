@model WebXeDap.Models.tintuc

@{
    ViewData["Title"] = Model.tieude;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <h2 class="mb-3">@Model.tieude</h2>
            <p class="text-muted">Ngày đăng: @Model.ngaytao?.ToString("dd/MM/yyyy")</p>

            <img src="@Model.hinhanh" class="img-fluid mb-4 rounded" alt="Ảnh tin tức" style="max-height: 400px; object-fit: cover;" />

            <div class="bg-light p-4 rounded shadow-sm">
                @Html.Raw(Model.noidung)
            </div>
        </div>
    </div>
</div>
